---
import type { ExifCleanerUI } from './index';

interface Props {
  ui: ExifCleanerUI;
}

const { ui } = Astro.props;
---

<div class="ec-root" id="ec-root" data-ui={JSON.stringify(ui)}>
  <div class="ec-card">

    <div id="ec-initial" class="ec-drop">
      <input type="file" id="ec-file" accept="image/jpeg,image/png,image/webp" class="ec-hidden" />
      <div class="ec-drop-icon">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.35 10.04A7.49 7.49 0 0 0 12 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 0 0 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zm-4.35 3.96h-3v3H9v-3H6v-2h3V8h2v3h3v2z"/>
        </svg>
      </div>
      <h3 class="ec-title">{ui.dropTitle}</h3>
      <p class="ec-subtitle">{ui.dropSubtitle}</p>

      <div class="ec-badges">
        <div class="ec-badge">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color:#10b981">
            <path d="M12 1C6.48 1 2 5.48 2 11s4.48 10 10 10 10-4.48 10-10S17.52 1 12 1zm-2 15l-5-5 1.41-1.41L10 13.17l7.59-7.59L19 7l-9 9z"/>
          </svg>
          <span>{ui.privacySecureLabel}</span>
        </div>
        <div class="ec-badge">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color:#f59e0b">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
          </svg>
          <span>{ui.offlineLabel}</span>
        </div>
      </div>
    </div>

    <div id="ec-processing" class="ec-processing ec-hidden">
      <div class="ec-spinner"></div>
      <p class="ec-processing-text">{ui.processingText}</p>
    </div>

    <div id="ec-result" class="ec-result ec-hidden">
      <div class="ec-result-layout">
        <div class="ec-preview-col">
          <img id="ec-preview" class="ec-preview-img" src="#" alt="" />
          <div id="ec-metadata" class="ec-metadata"></div>
        </div>

        <div class="ec-actions-col">
          <button id="ec-download" class="ec-btn ec-btn-primary">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
            </svg>
            <span>{ui.downloadButton}</span>
          </button>
          <button id="ec-reset" class="ec-btn ec-btn-secondary">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/>
            </svg>
            <span>{ui.resetButton}</span>
          </button>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  import { extractExif, createCleanImage } from './logic';
  import type { ExifCleanerUI } from './index';

  function init() {
    const root = document.getElementById('ec-root');
    if (!root) return;

    const ui = JSON.parse(root.dataset.ui ?? '{}') as ExifCleanerUI;

    function renderMetadata(tags: Record<string, string | number | boolean | undefined>, container: HTMLElement, riskTitle: string) {
      const keys = Object.keys(tags);
      if (keys.length === 0) {
        container.innerHTML = `<div class="ec-no-metadata">${ui.noMetadataFound}</div>`;
        return;
      }
      let html = `<div class="ec-metadata-title">${riskTitle}</div><ul class="ec-metadata-list">`;
      if (tags.GPSLocation) html += `<li><span>${ui.gpsLabel}</span> <span>${tags.GPSLocation}</span></li>`;
      if (tags.Model) html += `<li><span>${ui.cameraLabel}</span> <span>${tags.Model}</span></li>`;
      if (tags.DateTimeOriginal) html += `<li><span>${ui.dateLabel}</span> <span>${tags.DateTimeOriginal}</span></li>`;
      container.innerHTML = html + '</ul>';
    }
    const initial = root.querySelector('#ec-initial') as HTMLElement;
    const processing = root.querySelector('#ec-processing') as HTMLElement;
    const result = root.querySelector('#ec-result') as HTMLElement;
    const fileInput = root.querySelector('#ec-file') as HTMLInputElement;
    const preview = root.querySelector('#ec-preview') as HTMLImageElement;
    const metadata = root.querySelector('#ec-metadata') as HTMLElement;
    const downloadBtn = root.querySelector('#ec-download') as HTMLButtonElement;
    const resetBtn = root.querySelector('#ec-reset') as HTMLButtonElement;

    async function processFile(file: File) {
      processing.classList.remove('ec-hidden');
      initial.classList.add('ec-hidden');

      const reader = new FileReader();
      reader.onload = async (e) => {
        const exifData = await extractExif(file);
        const img = new Image();
        img.onload = async () => {
          preview.src = img.src;
          renderMetadata(exifData, metadata, ui.privacyRiskTitle);
          const blob = await createCleanImage(img);

          downloadBtn.onclick = () => {
            if (!blob) return;
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `CLEAN_${file.name.split('.')[0]}.webp`;
            a.click();
            setTimeout(() => URL.revokeObjectURL(url), 100);
          };

          processing.classList.add('ec-hidden');
          result.classList.remove('ec-hidden');
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    }

    root.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('button') && result.classList.contains('ec-hidden')) {
        fileInput.click();
      }
    });

    root.addEventListener('dragover', (e) => { e.preventDefault(); root.classList.add('ec-drop-active'); });
    root.addEventListener('dragleave', () => root.classList.remove('ec-drop-active'));
    root.addEventListener('drop', (e) => {
      e.preventDefault();
      root.classList.remove('ec-drop-active');
      if (e.dataTransfer?.files[0]) processFile(e.dataTransfer.files[0]);
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files?.[0]) processFile(fileInput.files[0]);
    });

    resetBtn.addEventListener('click', () => {
      result.classList.add('ec-hidden');
      initial.classList.remove('ec-hidden');
      fileInput.value = '';
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
:global(.ec-root) {
  --ec-bg: #fff;
  --ec-bg-elevated: #f8fafc;
  --ec-border: #e2e8f0;
  --ec-text: #0f172a;
  --ec-text-muted: #64748b;
  --ec-accent: #6366f1;
  --ec-accent-alpha: rgba(99, 102, 241, 0.08);
  --ec-accent-alpha-hover: rgba(99, 102, 241, 0.02);
  --ec-shadow: rgba(0, 0, 0, 0.15);

  padding: 2.5rem 1.5rem;
  max-width: 1000px;
  margin: 0 auto;
}

:global(.theme-dark .ec-root) {
  --ec-bg: #18181b;
  --ec-bg-elevated: #27272a;
  --ec-border: #3f3f46;
  --ec-text: #f4f4f5;
  --ec-text-muted: #71717a;
  --ec-accent: #818cf8;
  --ec-accent-alpha: rgba(129, 140, 248, 0.12);
  --ec-accent-alpha-hover: rgba(129, 140, 248, 0.02);
  --ec-shadow: rgba(0, 0, 0, 0.3);
}

:global(.ec-card) {
  background: var(--ec-bg);
  border: 1px solid var(--ec-border);
  border-radius: 3rem;
  padding: 1.5rem;
  box-shadow: 0 45px 120px -30px var(--ec-shadow);
  position: relative;
  overflow: hidden;
}

:global(.ec-drop) {
  padding: 4rem 2rem;
  border: 3px dashed var(--ec-border);
  border-radius: 2.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  cursor: pointer;
  gap: 1.5rem;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

:global(.ec-drop:hover),
:global(.ec-drop-active) {
  border-color: var(--ec-accent);
  background: var(--ec-accent-alpha-hover);
}

:global(.ec-drop-icon) {
  width: 6rem;
  height: 6rem;
  background: var(--ec-accent-alpha);
  border-radius: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ec-accent);
}

:global(.ec-drop-icon svg) {
  width: 3rem;
  height: 3rem;
}

:global(.ec-title) {
  font-size: 2.5rem;
  font-weight: 950;
  color: var(--ec-text);
  margin: 0;
}

:global(.ec-subtitle) {
  font-size: 1.15rem;
  color: var(--ec-text-muted);
  max-width: 500px;
  margin: 0;
  font-weight: 700;
}

:global(.ec-badges) {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}

:global(.ec-badge) {
  padding: 0.6rem 1.25rem;
  background: var(--ec-bg-elevated);
  border-radius: 2rem;
  font-size: 0.8rem;
  font-weight: 800;
  color: var(--ec-text-muted);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

:global(.ec-badge svg) {
  width: 1rem;
  height: 1rem;
  flex-shrink: 0;
}

:global(.ec-processing) {
  padding: 5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
}

:global(.ec-spinner) {
  width: 4rem;
  height: 4rem;
  border: 4px solid var(--ec-accent-alpha);
  border-top-color: var(--ec-accent);
  border-radius: 50%;
  animation: ec-spin 0.8s linear infinite;
}

:global(.ec-processing-text) {
  font-weight: 800;
  color: var(--ec-text);
  margin: 0;
}

:global(.ec-result) {
  padding: 2.5rem;
  display: flex;
  flex-direction: column;
  animation: ec-slide-up 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

:global(.ec-result-layout) {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
}

@media (max-width: 800px) {
  :global(.ec-result-layout) {
    grid-template-columns: 1fr;
  }
}

:global(.ec-preview-col) {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

:global(.ec-preview-img) {
  width: 100%;
  border-radius: 1.5rem;
  box-shadow: 0 20px 50px var(--ec-shadow);
  display: block;
}

:global(.ec-metadata) {
  background: var(--ec-bg-elevated);
  border: 1px solid var(--ec-border);
  border-radius: 1.25rem;
  padding: 1.5rem;
  min-height: 150px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

:global(.ec-no-metadata) {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--ec-text-muted);
  text-align: center;
}

:global(.ec-metadata-title) {
  color: var(--ec-accent);
  font-weight: 700;
  margin-bottom: 1rem;
  font-size: 0.9rem;
}

:global(.ec-metadata-list) {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

:global(.ec-metadata-list li) {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--ec-text);
}

:global(.ec-metadata-list li span:first-child) {
  font-weight: 700;
}

:global(.ec-metadata-list li span:last-child) {
  color: var(--ec-text-muted);
}

:global(.ec-actions-col) {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

:global(.ec-btn) {
  padding: 1.25rem;
  border-radius: 1.5rem;
  font-weight: 950;
  font-size: 1.1rem;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  transition: all 0.2s;
}

:global(.ec-btn svg) {
  width: 1.25rem;
  height: 1.25rem;
}

:global(.ec-btn-primary) {
  background: var(--ec-accent);
  color: #fff;
  box-shadow: 0 15px 35px -10px var(--ec-accent);
}

:global(.ec-btn-primary:hover) {
  transform: translateY(-2px);
  box-shadow: 0 20px 45px -10px var(--ec-accent);
}

:global(.ec-btn-secondary) {
  background: var(--ec-bg-elevated);
  border: 1px solid var(--ec-border);
  color: var(--ec-text);
}

:global(.ec-btn-secondary:hover) {
  border-color: var(--ec-accent);
  color: var(--ec-accent);
}

.ec-hidden {
  display: none;
}

@keyframes ec-spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes ec-slide-up {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>
