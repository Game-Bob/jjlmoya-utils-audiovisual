---
import type { TvDistanceUI } from './index';

interface Props {
  ui: TvDistanceUI;
}

const { ui } = Astro.props;
---

<div class="tvd-root" id="tv-distance-root" data-ui={JSON.stringify(ui)}>
  <div class="tvd-card">

    <div class="tvd-body">

      <div class="tvd-left">

        <div class="tvd-specs-block">
          <h3 class="tvd-specs-title">
            <svg viewBox="0 0 24 24" class="tvd-tv-icon" aria-hidden="true">
              <path d="M8.16 3L6.75 4.41L9.34 7H4c-1.11 0-2 .89-2 2v10c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V9c0-1.11-.89-2-2-2h-5.34l2.59-2.59L15.84 3L12 6.84zM4 9h13v10H4zm15.5 0a1 1 0 0 1 1 1a1 1 0 0 1-1 1a1 1 0 0 1-1-1a1 1 0 0 1 1-1m0 3a1 1 0 0 1 1 1a1 1 0 0 1-1 1a1 1 0 0 1-1-1a1 1 0 0 1 1-1"/>
            </svg>
            {ui.specTitle}
          </h3>

          <div class="tvd-field">
            <div class="tvd-field-row">
              <span class="tvd-label">{ui.diagonalLabel}</span>
              <span id="tvd-diagonal-display" class="tvd-diagonal-val">55"</span>
            </div>
            <input type="range" id="tvd-diagonal" min="32" max="100" value="55" class="tvd-slider" />
          </div>

          <div class="tvd-field">
            <span class="tvd-label">{ui.resolutionLabel}</span>
            <div class="tvd-res-grid">
              <button class="tvd-res-btn" data-res="1080p">1080p</button>
              <button class="tvd-res-btn tvd-res-btn-active" data-res="4k">4K</button>
              <button class="tvd-res-btn" data-res="8k">8K</button>
            </div>
          </div>
        </div>

        <div class="tvd-thx-block">
          <div class="tvd-thx-header">
            <svg viewBox="0 0 24 24" class="tvd-thx-icon" aria-hidden="true">
              <path d="M11 9h2V7h-2m1 13c-4.41 0-8-3.59-8-8s3.59-8 8-8s8 3.59 8 8s-3.59 8-8 8m0-18A10 10 0 0 0 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2m-1 15h2v-6h-2z"/>
            </svg>
            <span class="tvd-thx-title">{ui.thxRecommendation}</span>
          </div>
          <p class="tvd-thx-desc">{ui.thxDescription}</p>
        </div>

      </div>

      <div class="tvd-right">

        <div class="tvd-sim-badge">
          <span class="tvd-sim-dot"></span>
          <span class="tvd-sim-badge-text">{ui.simulationBadge}</span>
        </div>

        <div class="tvd-sim-area">

          <div id="tvd-tv-visual" class="tvd-tv-visual">
            <div class="tvd-tv-screen">
              <div class="tvd-screen-gradient"></div>
              <svg viewBox="0 0 24 24" class="tvd-screen-ghost" aria-hidden="true">
                <path d="M21 3H3c-1.11 0-2 .89-2 2v12a2 2 0 0 0 2 2h5v2h8v-2h5a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2m0 14H3V5h18m-5 6l-7 4V7"/>
              </svg>
              <div class="tvd-screen-inset"></div>
            </div>
            <div class="tvd-stand-neck"></div>
            <div class="tvd-stand-base"></div>
            <div class="tvd-tv-tooltip">
              <span id="tvd-width-display">—</span> {ui.tvWidthLabel}
            </div>
          </div>

          <div id="tvd-line" class="tvd-distance-line">
            <div class="tvd-line-dashed"></div>
          </div>

          <div class="tvd-person">
            <div class="tvd-person-inner">
              <div class="tvd-person-head"></div>
              <div class="tvd-person-body"></div>
            </div>
            <div class="tvd-location-card">
              <span class="tvd-location-label">{ui.userLocationLabel}</span>
              <span id="tvd-distance-display" class="tvd-location-val">—</span>
            </div>
          </div>

        </div>

        <div class="tvd-stats">
          <div class="tvd-stat">
            <span class="tvd-stat-label">{ui.minLimitLabel}</span>
            <span id="tvd-min" class="tvd-stat-val">—</span>
          </div>
          <div class="tvd-stat tvd-stat-opt">
            <span class="tvd-stat-label">{ui.optimalLimitLabel}</span>
            <span id="tvd-opt" class="tvd-stat-val">—</span>
          </div>
          <div class="tvd-stat">
            <span class="tvd-stat-label">{ui.maxLimitLabel}</span>
            <span id="tvd-max" class="tvd-stat-val">—</span>
          </div>
        </div>

      </div>

    </div>

  </div>
</div>

<script>
  import { calculateViewingDistance, getDimensionsFromDiagonal } from './logic';
  import type { TVSpecs } from './logic';
  import type { TvDistanceUI } from './index';

  function init() {
    const root = document.getElementById('tv-distance-root');
    if (!root) return;

    const labels = JSON.parse(root.dataset.ui ?? '{}') as TvDistanceUI;

    const diagonalInput = root.querySelector('#tvd-diagonal') as HTMLInputElement;
    const diagonalDisplay = root.querySelector('#tvd-diagonal-display') as HTMLElement;
    const resBtns = root.querySelectorAll('.tvd-res-btn') as NodeListOf<HTMLButtonElement>;
    const tvVisual = root.querySelector('#tvd-tv-visual') as HTMLElement;
    const widthDisplay = root.querySelector('#tvd-width-display') as HTMLElement;
    const lineEl = root.querySelector('#tvd-line') as HTMLElement;
    const distanceDisplay = root.querySelector('#tvd-distance-display') as HTMLElement;
    const minEl = root.querySelector('#tvd-min') as HTMLElement;
    const optEl = root.querySelector('#tvd-opt') as HTMLElement;
    const maxEl = root.querySelector('#tvd-max') as HTMLElement;

    let currentRes: TVSpecs['resolution'] = '4k';

    function update() {
      const diagonal = parseInt(diagonalInput.value);
      diagonalDisplay.textContent = `${diagonal}"`;

      const specs: TVSpecs = { diagonalInches: diagonal, resolution: currentRes, aspectRatio: 16 / 9 };
      const dist = calculateViewingDistance(specs);
      const dims = getDimensionsFromDiagonal(diagonal);

      minEl.textContent = `${dist.min.toFixed(2)}${labels.unitMeters}`;
      optEl.textContent = `${dist.optimal.toFixed(2)}${labels.unitMeters}`;
      maxEl.textContent = `${dist.max.toFixed(2)}${labels.unitMeters}`;
      distanceDisplay.textContent = `${dist.optimal.toFixed(2)}${labels.unitMeters}`;
      widthDisplay.textContent = String(Math.round(dims.width));

      const scale = 1.8;
      tvVisual.style.width = `${Math.round(dims.width * scale)}px`;

      const lineH = Math.max(60, dist.optimal * 80);
      lineEl.style.height = `${lineH}px`;

      resBtns.forEach(b => b.classList.toggle('tvd-res-btn-active', b.dataset.res === currentRes));
    }

    diagonalInput.addEventListener('input', update);
    resBtns.forEach(b => b.addEventListener('click', () => {
      currentRes = b.dataset.res as TVSpecs['resolution'];
      update();
    }));

    update();
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
:global(.tvd-root) {
  --tvd-bg: #fff;
  --tvd-bg-muted: #f8fafc;
  --tvd-bg-sim: #f1f5f9;
  --tvd-border: #e2e8f0;
  --tvd-text: #0f172a;
  --tvd-text-muted: #94a3b8;
  --tvd-primary: #2563eb;
  --tvd-primary-light: rgba(59,130,246,0.06);
  --tvd-primary-border: rgba(59,130,246,0.12);
  --tvd-shadow: rgba(0,0,0,0.06);
  --tvd-radius: 1.5rem;

  max-width: 1000px;
  margin: 0 auto;
  padding: 1rem;
}

:global(.theme-dark .tvd-root) {
  --tvd-bg: #09090b;
  --tvd-bg-muted: #18181b;
  --tvd-bg-sim: #09090b;
  --tvd-border: #27272a;
  --tvd-text: #fafafa;
  --tvd-text-muted: #71717a;
  --tvd-primary: #60a5fa;
  --tvd-primary-light: rgba(96,165,250,0.08);
  --tvd-primary-border: rgba(96,165,250,0.15);
  --tvd-shadow: rgba(0,0,0,0.4);
}

:global(.tvd-card) {
  background: var(--tvd-bg);
  border: 1px solid var(--tvd-border);
  border-radius: var(--tvd-radius);
  box-shadow: 0 4px 32px var(--tvd-shadow);
  overflow: hidden;
}

:global(.tvd-body) {
  display: grid;
  grid-template-columns: 320px 1fr;
}

@media (max-width: 720px) {
  :global(.tvd-body) {
    grid-template-columns: 1fr;
  }
}

:global(.tvd-left) {
  padding: 1.75rem;
  border-right: 1px solid var(--tvd-border);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

@media (max-width: 720px) {
  :global(.tvd-left) {
    border-right: none;
    border-bottom: 1px solid var(--tvd-border);
  }
}

:global(.tvd-specs-block) {
  background: var(--tvd-bg);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

:global(.tvd-specs-title) {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--tvd-text);
  margin: 0 0 0.25rem;
}

:global(.tvd-tv-icon) {
  width: 1.25rem;
  height: 1.25rem;
  fill: var(--tvd-primary);
  flex-shrink: 0;
}

:global(.tvd-label) {
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--tvd-text-muted);
}

:global(.tvd-field) {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

:global(.tvd-field-row) {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

:global(.tvd-diagonal-val) {
  font-size: 0.85rem;
  font-weight: 800;
  color: var(--tvd-primary);
}

:global(.tvd-slider) {
  width: 100%;
  height: 6px;
  accent-color: var(--tvd-primary);
  cursor: pointer;
  border-radius: 9999px;
}

:global(.tvd-res-grid) {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.5rem;
}

:global(.tvd-res-btn) {
  padding: 0.625rem 0.25rem;
  border-radius: 0.75rem;
  border: 1px solid var(--tvd-border);
  background: var(--tvd-bg);
  color: var(--tvd-text-muted);
  font-size: 0.75rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
}

:global(.tvd-res-btn:hover:not(.tvd-res-btn-active)) {
  border-color: var(--tvd-primary);
  opacity: 0.7;
}

:global(.tvd-res-btn-active) {
  background: var(--tvd-primary);
  color: #fff;
  border-color: var(--tvd-primary);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
}

:global(.tvd-thx-block) {
  background: var(--tvd-primary-light);
  border: 1px solid var(--tvd-primary-border);
  border-radius: 1rem;
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

:global(.tvd-thx-header) {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

:global(.tvd-thx-icon) {
  width: 1.125rem;
  height: 1.125rem;
  fill: var(--tvd-primary);
  flex-shrink: 0;
}

:global(.tvd-thx-title) {
  font-size: 0.8rem;
  font-weight: 800;
  color: var(--tvd-primary);
}

:global(.tvd-thx-desc) {
  font-size: 0.75rem;
  line-height: 1.6;
  color: var(--tvd-primary);
  opacity: 0.8;
  margin: 0;
}

:global(.tvd-right) {
  display: flex;
  flex-direction: column;
  background: var(--tvd-bg);
}

:global(.tvd-sim-badge) {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 1.25rem 1.5rem 0;
}

:global(.tvd-sim-dot) {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--tvd-primary);
  animation: tvd-pulse 2s infinite;
}

@keyframes tvd-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

:global(.tvd-sim-badge-text) {
  font-size: 0.6rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--tvd-text-muted);
}

:global(.tvd-sim-area) {
  flex: 1;
  background: var(--tvd-bg-sim);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 2rem 1rem 1.5rem;
  position: relative;
  min-height: 400px;
}

:global(.tvd-tv-visual) {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: width 0.5s ease;
}

:global(.tvd-tv-screen) {
  background: #0a0a0f;
  border: 3px solid #27272a;
  border-radius: 0.5rem;
  width: 100%;
  aspect-ratio: 16/9;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}

:global(.tvd-screen-gradient) {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(59,130,246,0.1) 0%, transparent 60%);
}

:global(.tvd-screen-ghost) {
  width: 30%;
  height: 30%;
  fill: rgba(96,165,250,0.2);
  position: relative;
  z-index: 1;
}

:global(.tvd-screen-inset) {
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 40px rgba(59,130,246,0.08);
}

:global(.tvd-stand-neck) {
  width: 16px;
  height: 16px;
  background: #27272a;
  margin-top: -1px;
}

:global(.tvd-stand-base) {
  width: 70px;
  height: 6px;
  background: #27272a;
  border-radius: 3px;
}

:global(.tvd-tv-tooltip) {
  position: absolute;
  top: -2.25rem;
  left: 50%;
  transform: translateX(-50%);
  background: var(--tvd-text);
  color: var(--tvd-bg);
  font-size: 0.65rem;
  font-weight: 800;
  padding: 0.3rem 0.75rem;
  border-radius: 9999px;
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.25s;
  pointer-events: none;
}

:global(.tvd-tv-visual:hover .tvd-tv-tooltip) {
  opacity: 1;
}

:global(.tvd-distance-line) {
  width: 1px;
  position: relative;
  transition: height 0.5s ease;
  margin: 0.25rem 0;
}

:global(.tvd-line-dashed) {
  width: 100%;
  height: 100%;
  border-left: 1px dashed rgba(59,130,246,0.4);
}

:global(.tvd-person) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

:global(.tvd-person-inner) {
  display: flex;
  flex-direction: column;
  align-items: center;
}

:global(.tvd-person-head) {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  background: var(--tvd-border);
  border: 2px solid var(--tvd-text-muted);
  opacity: 0.7;
  margin-bottom: 0.25rem;
}

:global(.tvd-person-body) {
  width: 4rem;
  height: 2rem;
  background: var(--tvd-primary);
  border-radius: 1.5rem 1.5rem 0 0;
  box-shadow: 0 4px 16px rgba(37,99,235,0.3);
}

:global(.tvd-location-card) {
  background: var(--tvd-bg);
  border: 1px solid var(--tvd-border);
  border-radius: 1rem;
  padding: 0.625rem 1.25rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  box-shadow: 0 4px 16px var(--tvd-shadow);
}

:global(.tvd-location-label) {
  font-size: 0.6rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--tvd-text-muted);
}

:global(.tvd-location-val) {
  font-size: 1.25rem;
  font-weight: 900;
  color: var(--tvd-primary);
  line-height: 1;
}

:global(.tvd-stats) {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  background: var(--tvd-bg-muted);
  border-top: 1px solid var(--tvd-border);
}

:global(.tvd-stat) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  padding: 1rem 0.5rem;
  border-radius: 1rem;
  transition: background 0.2s;
}

:global(.tvd-stat:hover) {
  background: var(--tvd-bg);
}

:global(.tvd-stat-opt) {
  background: var(--tvd-bg);
  border: 1px solid var(--tvd-border);
  box-shadow: 0 2px 8px var(--tvd-shadow);
}

:global(.tvd-stat-label) {
  font-size: 0.6rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--tvd-text-muted);
}

:global(.tvd-stat-opt .tvd-stat-label) {
  color: var(--tvd-primary);
}

:global(.tvd-stat-val) {
  font-size: 1.2rem;
  font-weight: 900;
  color: var(--tvd-text);
}

:global(.tvd-stat-opt .tvd-stat-val) {
  font-size: 1.75rem;
  color: var(--tvd-primary);
}
</style>
