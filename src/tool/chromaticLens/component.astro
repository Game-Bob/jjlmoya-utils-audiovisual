---
import type { ChromaticLensUI } from './index';

interface Props {
  ui: ChromaticLensUI;
}

const { ui } = Astro.props;
---

<div class="cl-root" id="cl-root" data-ui={JSON.stringify(ui)}>
  <div class="cl-card">

    <div id="cl-empty" class="cl-drop">
      <input type="file" id="cl-file" accept="image/*" class="cl-hidden" />
      <div class="cl-drop-icon">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8zm-5.5 9c-.83 0-1.5-.67-1.5-1.5S5.67 9 6.5 9 8 9.67 8 10.5 7.33 12 6.5 12zm3-4C8.67 8 8 7.33 8 6.5S8.67 5 9.5 5s1.5.67 1.5 1.5S10.33 8 9.5 8zm5 0c-.83 0-1.5-.67-1.5-1.5S13.67 5 14.5 5s1.5.67 1.5 1.5S15.33 8 14.5 8zm3 4c-.83 0-1.5-.67-1.5-1.5S16.67 9 17.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
        </svg>
      </div>
      <h3 class="cl-drop-title">{ui.dropTitle}</h3>
      <p class="cl-drop-sub">{ui.dropSubtitle}</p>
    </div>

    <div id="cl-workspace" class="cl-workspace cl-hidden">
      <div id="cl-mini-drop" class="cl-mini-drop">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.35 10.04A7.49 7.49 0 0 0 12 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 0 0 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/>
        </svg>
        <span>{ui.changeImage}</span>
      </div>

      <div class="cl-config-bar">
        <div class="cl-config-item">
          <span class="cl-config-label">{ui.colorCountLabel}</span>
          <select id="cl-count" class="cl-count-select">
            <option value="5">5</option>
            <option value="8" selected>8</option>
            <option value="12">12</option>
            <option value="16">16</option>
          </select>
        </div>
      </div>

      <div class="cl-result-layout">
        <div class="cl-preview-col">
          <img id="cl-preview" class="cl-preview-img" src="#" alt="" />
        </div>

        <div class="cl-palette-col">
          <div class="cl-palette-header">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 3h4v4H3zm0 7h4v4H3zm0 7h4v4H3zm7-14h11v2H10zm0 7h11v2H10zm0 7h11v2H10z"/>
            </svg>
            <h4>{ui.paletteTitle}</h4>
          </div>
          <div id="cl-loader" class="cl-loader cl-hidden">
            <div class="cl-spinner"></div>
            <p class="cl-loader-text">{ui.processingLabel}</p>
          </div>
          <div id="cl-swatches" class="cl-swatches"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  import { extractPalette } from './logic';
  import type { ColorSwatch } from './logic';
  import type { ChromaticLensUI } from './index';

  function init() {
    const root = document.getElementById('cl-root');
    if (!root) return;

    const labels = JSON.parse(root.dataset.ui ?? '{}') as ChromaticLensUI;
    const canvas = document.createElement('canvas');
    const ctxRaw = canvas.getContext('2d', { willReadFrequently: true });
    if (!ctxRaw) return;
    const ctx = ctxRaw;

    const fileInput = root.querySelector('#cl-file') as HTMLInputElement;
    const emptyState = root.querySelector('#cl-empty') as HTMLElement;
    const workspace = root.querySelector('#cl-workspace') as HTMLElement;
    const miniDrop = root.querySelector('#cl-mini-drop') as HTMLElement;
    const preview = root.querySelector('#cl-preview') as HTMLImageElement;
    const countSelect = root.querySelector('#cl-count') as HTMLSelectElement;
    const loader = root.querySelector('#cl-loader') as HTMLElement;
    const swatches = root.querySelector('#cl-swatches') as HTMLElement;

    let currentImageData: Uint8ClampedArray | null = null;
    let isProcessing = false;

    function renderPalette(palette: ColorSwatch[]) {
      swatches.innerHTML = '';
      palette.forEach((item) => {
        const el = document.createElement('div');
        el.className = 'cl-swatch';
        el.innerHTML = `
          <div class="cl-swatch-color" style="background-color:${item.hex}"></div>
          <div class="cl-swatch-info">
            <span class="cl-swatch-hex">${item.hex}</span>
            <span class="cl-swatch-action">${labels.copyLabel}</span>
          </div>
        `;
        el.addEventListener('click', () => {
          navigator.clipboard.writeText(item.hex);
          const action = el.querySelector('.cl-swatch-action') as HTMLElement;
          const prev = action.textContent;
          action.textContent = labels.copiedLabel;
          el.classList.add('cl-swatch-copied');
          setTimeout(() => {
            action.textContent = prev;
            el.classList.remove('cl-swatch-copied');
          }, 2000);
        });
        swatches.appendChild(el);
      });
    }

    function processPalette() {
      if (!currentImageData || isProcessing) return;
      isProcessing = true;
      loader.classList.remove('cl-hidden');
      swatches.classList.add('cl-hidden');
      const count = parseInt(countSelect.value);
      requestAnimationFrame(() => {
        setTimeout(() => {
          const palette = extractPalette(currentImageData!, count);
          renderPalette(palette);
          loader.classList.add('cl-hidden');
          swatches.classList.remove('cl-hidden');
          isProcessing = false;
        }, 50);
      });
    }

    function handleFile(file: File) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          ctx.drawImage(img, 0, 0);
          currentImageData = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
          preview.src = img.src;
          emptyState.classList.add('cl-hidden');
          workspace.classList.remove('cl-hidden');
          processPalette();
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    }

    emptyState.addEventListener('click', () => fileInput.click());
    miniDrop.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => {
      if (fileInput.files?.[0]) handleFile(fileInput.files[0]);
    });
    countSelect.addEventListener('change', processPalette);

    root.addEventListener('dragover', (e) => { e.preventDefault(); emptyState.classList.add('cl-drop-active'); });
    root.addEventListener('dragleave', () => emptyState.classList.remove('cl-drop-active'));
    root.addEventListener('drop', (e) => {
      e.preventDefault();
      emptyState.classList.remove('cl-drop-active');
      if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0]);
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
:global(.cl-root) {
  --cl-bg: #fff;
  --cl-bg-elevated: #f8fafc;
  --cl-border: #e2e8f0;
  --cl-text: #0f172a;
  --cl-text-muted: #64748b;
  --cl-accent: #6366f1;
  --cl-accent-alpha: rgba(99, 102, 241, 0.08);
  --cl-accent-alpha-hover: rgba(99, 102, 241, 0.04);
  --cl-emerald: #10b981;
  --cl-emerald-alpha: rgba(16, 185, 129, 0.06);
  --cl-shadow: rgba(0, 0, 0, 0.15);

  padding: 2.5rem 1.5rem;
  max-width: 1000px;
  margin: 0 auto;
}

:global(.theme-dark .cl-root) {
  --cl-bg: #18181b;
  --cl-bg-elevated: #27272a;
  --cl-border: #3f3f46;
  --cl-text: #f4f4f5;
  --cl-text-muted: #71717a;
  --cl-accent: #818cf8;
  --cl-accent-alpha: rgba(129, 140, 248, 0.12);
  --cl-accent-alpha-hover: rgba(129, 140, 248, 0.06);
  --cl-emerald: #34d399;
  --cl-emerald-alpha: rgba(52, 211, 153, 0.08);
  --cl-shadow: rgba(0, 0, 0, 0.5);
}

:global(.cl-card) {
  background: var(--cl-bg);
  border: 1px solid var(--cl-border);
  border-radius: 3rem;
  padding: 1.5rem;
  box-shadow: 0 45px 120px -30px var(--cl-shadow);
  position: relative;
  overflow: hidden;
}

:global(.cl-drop) {
  padding: 5rem 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 3px dashed var(--cl-border);
  border-radius: 2.5rem;
  cursor: pointer;
  transition: all 0.2s ease;
  text-align: center;
  gap: 0.5rem;
}

:global(.cl-drop:hover),
:global(.cl-drop-active) {
  background: var(--cl-accent-alpha-hover);
  border-color: var(--cl-accent);
}

:global(.cl-drop-icon) {
  width: 5rem;
  height: 5rem;
  background: var(--cl-accent-alpha);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
  color: var(--cl-accent);
}

:global(.cl-drop-icon svg) {
  width: 2.5rem;
  height: 2.5rem;
}

:global(.cl-drop-title) {
  font-size: 2rem;
  font-weight: 950;
  color: var(--cl-text);
  margin: 0;
}

:global(.cl-drop-sub) {
  font-size: 1.1rem;
  color: var(--cl-text-muted);
  margin: 0;
  font-weight: 600;
}

:global(.cl-workspace) {
  padding: 1.5rem;
}

:global(.cl-mini-drop) {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1.25rem;
  background: var(--cl-bg-elevated);
  border: 1px solid var(--cl-border);
  border-radius: 1rem;
  font-size: 0.75rem;
  font-weight: 800;
  color: var(--cl-text-muted);
  cursor: pointer;
  margin-bottom: 2rem;
  transition: border-color 0.2s, color 0.2s;
}

:global(.cl-mini-drop:hover) {
  border-color: var(--cl-accent);
  color: var(--cl-accent);
}

:global(.cl-mini-drop svg) {
  width: 1.1rem;
  height: 1.1rem;
}

:global(.cl-config-bar) {
  padding: 1rem 0;
  margin-bottom: 2rem;
  border-bottom: 1px solid var(--cl-border);
  display: flex;
  justify-content: flex-end;
}

:global(.cl-config-item) {
  display: flex;
  align-items: center;
  gap: 1rem;
}

:global(.cl-config-label) {
  font-size: 0.75rem;
  font-weight: 900;
  text-transform: uppercase;
  color: var(--cl-text-muted);
  letter-spacing: 0.1em;
}

:global(.cl-count-select) {
  padding: 0.5rem 1rem;
  border-radius: 0.75rem;
  background: var(--cl-bg-elevated);
  border: 1px solid var(--cl-border);
  color: var(--cl-text);
  font-weight: 800;
  cursor: pointer;
}

:global(.cl-result-layout) {
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 3rem;
}

@media (max-width: 800px) {
  :global(.cl-result-layout) {
    grid-template-columns: 1fr;
  }
}

:global(.cl-preview-col) {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

:global(.cl-preview-img) {
  width: 100%;
  border-radius: 1.5rem;
  box-shadow: 0 20px 40px var(--cl-shadow);
  display: block;
}

:global(.cl-palette-col) {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

:global(.cl-palette-header) {
  display: flex;
  align-items: center;
  gap: 1rem;
  color: var(--cl-accent);
}

:global(.cl-palette-header svg) {
  width: 1.25rem;
  height: 1.25rem;
  flex-shrink: 0;
}

:global(.cl-palette-header h4) {
  font-size: 1.25rem;
  font-weight: 950;
  color: var(--cl-text);
  margin: 0;
}

:global(.cl-loader) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 2rem 0;
}

:global(.cl-spinner) {
  width: 3rem;
  height: 3rem;
  border: 3px solid var(--cl-accent-alpha);
  border-top-color: var(--cl-accent);
  border-radius: 50%;
  animation: cl-spin 0.8s linear infinite;
}

:global(.cl-loader-text) {
  font-size: 0.75rem;
  font-weight: 900;
  text-transform: uppercase;
  color: var(--cl-text-muted);
  letter-spacing: 0.1em;
  margin: 0;
}

:global(.cl-swatches) {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  animation: cl-fade-up 0.5s ease;
}

:global(.cl-swatch) {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  background: var(--cl-bg-elevated);
  border-radius: 1.25rem;
  padding: 1rem;
  border: 1px solid var(--cl-border);
  cursor: pointer;
  transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.2s;
}

:global(.cl-swatch:hover) {
  transform: scale(1.02);
  border-color: var(--cl-accent);
}

:global(.cl-swatch-copied) {
  background: var(--cl-emerald-alpha);
  border-color: var(--cl-emerald);
}

:global(.cl-swatch-color) {
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 0.75rem;
  box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

:global(.cl-swatch-info) {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

:global(.cl-swatch-hex) {
  font-weight: 950;
  color: var(--cl-text);
  font-size: 1.25rem;
}

:global(.cl-swatch-action) {
  font-size: 0.7rem;
  font-weight: 900;
  color: var(--cl-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

:global(.cl-hidden) {
  display: none;
}

@keyframes cl-spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes cl-fade-up {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>
