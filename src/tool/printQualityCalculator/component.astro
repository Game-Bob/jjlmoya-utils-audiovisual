---
import { Icon } from 'astro-icon/components';
import type { PrintQualityCalculatorUI } from './index';

interface Props {
  ui: PrintQualityCalculatorUI;
}

const { ui } = Astro.props;
---

<div class="pq-wrapper" id="pq-root" data-ui={JSON.stringify(ui)}>
    <div
        id="drop-zone"
        class="pq-drop-zone pq-group"
    >
        <input type="file" id="file-input" class="pq-hidden" accept="image/webp, image/jpeg, image/png, image/tiff" />

        <div class="pq-drop-inner">
            <div class="pq-upload-icon-wrap pq-group-icon">
                <Icon name="mdi:cloud-upload" style="width:2.5rem;height:2.5rem" />
            </div>
            <div>
                <h3 class="pq-drop-title">{ui.dropTitle}</h3>
                <p class="pq-drop-sub">{ui.dropSubtitle}</p>
            </div>
        </div>

        <div class="pq-drop-overlay"></div>
    </div>

    <div id="results-area" class="pq-results pq-hidden">
        <div class="pq-file-card">
            <div class="pq-file-left">
                <div class="pq-preview-wrap">
                    <img id="preview-img" class="pq-preview-img" src="#" alt="Preview" />
                </div>
                <div class="pq-file-info">
                    <h3 id="file-name" class="pq-file-name">nombre_archivo.jpg</h3>
                    <div class="pq-file-meta">
                        <span class="pq-meta-item">
                            <Icon name="mdi:arrow-expand" style="width:1rem;height:1rem" />
                            <span id="pixel-dims">0 x 0 px</span>
                        </span>
                        <span class="pq-meta-item">
                            <Icon name="mdi:harddisk" style="width:1rem;height:1rem" />
                            <span id="file-size">0 MB</span>
                        </span>
                        <span class="pq-meta-item">
                            <Icon name="mdi:image-filter-hdr" style="width:1rem;height:1rem" />
                            <span id="megapixels">0 MP</span>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="pq-main-grid">
            <div class="pq-config-panel">
                <label class="pq-config-label">{ui.dpiDensityLabel}</label>

                <input
                    type="range"
                    id="dpi-slider"
                    min="72"
                    max="600"
                    value="300"
                    step="1"
                    class="pq-slider"
                />

                <div class="pq-dpi-row">
                    <input
                        type="number"
                        id="dpi-input"
                        value="300"
                        class="pq-dpi-number"
                    />
                    <span class="pq-dpi-label">{ui.dpiPointsLabel}</span>
                </div>

                <div class="pq-presets">
                    <button class="pq-preset-btn" data-val="72">{ui.dpiScreenLabel} (72)</button>
                    <button class="pq-preset-btn" data-val="150">{ui.dpiNewspaperLabel} (150)</button>
                    <button class="pq-preset-btn pq-preset-active" data-val="300">{ui.dpiPrintLabel} (300)</button>
                    <button class="pq-preset-btn" data-val="600">{ui.dpiFineArtLabel} (600)</button>
                </div>
            </div>

            <div class="pq-output-panel">
                <div class="pq-output-gradient">
                    <div class="pq-output-blur-bg"></div>
                    <h3 class="pq-output-subtitle">{ui.maxPrintTitle}</h3>

                    <div class="pq-output-size">
                        <span id="print-cm-w">0</span>
                        <span class="pq-size-sep">x</span>
                        <span id="print-cm-h">0</span>
                        <span class="pq-size-unit">cm</span>
                    </div>

                    <div class="pq-output-inches">
                        <span id="print-in-w">0</span>" x <span id="print-in-h">0</span>"
                    </div>

                    <div class="pq-quality-section">
                        <span id="quality-badge" class="pq-quality-badge">
                            <Icon name="mdi:check-decagram" style="width:1rem;height:1rem" />
                            <span id="quality-text">{ui.qualityExcellent}</span>
                        </span>
                        <p id="quality-desc" class="pq-quality-desc">{ui.qualityExcellentDesc}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="pq-formats-card">
            <h4 class="pq-formats-title">
                <Icon name="mdi:ruler-square" style="width:1.2rem;height:1.2rem;color:#6366f1" />
                {ui.standardFormatsTitle}
            </h4>
            <div class="pq-formats-scroll">
                <table class="pq-formats-table">
                    <thead>
                        <tr>
                            <th>{ui.formatColumn}</th>
                            <th>{ui.measureColumn} (cm)</th>
                            <th>{ui.supportColumn}</th>
                        </tr>
                    </thead>
                    <tbody id="formats-table-body"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    const root = document.currentScript?.closest('[data-ui]') || document.getElementById('pq-root');
    const ui = root ? JSON.parse(root.dataset.ui || '{}') : {};

    const PAPER_FORMATS = [
        { key: "postal", label: "A6", w: 10.5, h: 14.8 },
        { key: "quartilla", label: "A5", w: 14.8, h: 21.0 },
        { key: "folio", label: "A4", w: 21.0, h: 29.7 },
        { key: "doubleFolio", label: "A3", w: 29.7, h: 42.0 },
        { key: "smallPoster", label: "A2", w: 42.0, h: 59.4 },
        { key: "largePoster", label: "A1", w: 59.4, h: 84.1 },
        { key: "plane", label: "A0", w: 84.1, h: 118.9 },
    ];

    function initPQCalc() {
        console.log('DEBUG: initPQCalc called');
        console.log('DEBUG: ui object:', ui);
        console.log('DEBUG: ui.formatPostal:', ui.formatPostal);

        function getFormatName(format) {
            const keyMap = {
                postal: 'formatPostal',
                quartilla: 'formatQuartilla',
                folio: 'formatFolio',
                doubleFolio: 'formatDoubleFolio',
                smallPoster: 'formatSmallPoster',
                largePoster: 'formatLargePoster',
                plane: 'formatPlane'
            };
            const uiKey = keyMap[format.key];
            const result = format.label + ' (' + (ui[uiKey] || format.key) + ')';
            console.log('DEBUG: getFormatName for', format.key, '=', result, '(uiKey:', uiKey, ', ui[uiKey]:', ui[uiKey], ')');
            return result;
        }

        const dropZone = document.getElementById("drop-zone");
        const fileInput = document.getElementById("file-input");
        const resultsArea = document.getElementById("results-area");
        if (!dropZone || !fileInput || !resultsArea) return;

        const previewImg = document.getElementById("preview-img");
        const fileNameEl = document.getElementById("file-name");
        const pixelDimsEl = document.getElementById("pixel-dims");
        const fileSizeEl = document.getElementById("file-size");
        const megapixelsEl = document.getElementById("megapixels");
        const dpiSlider = document.getElementById("dpi-slider");
        const dpiInput = document.getElementById("dpi-input");
        const dpiPresets = document.querySelectorAll(".pq-preset-btn");
        const printCmW = document.getElementById("print-cm-w");
        const printCmH = document.getElementById("print-cm-h");
        const printInW = document.getElementById("print-in-w");
        const printInH = document.getElementById("print-in-h");
        const qualityBadge = document.getElementById("quality-badge");
        const qualityText = document.getElementById("quality-text");
        const qualityDesc = document.getElementById("quality-desc");
        const formatsTableBody = document.getElementById("formats-table-body");

        let currentWidth = 0;
        let currentHeight = 0;

        ["dragenter", "dragover", "dragleave", "drop"].forEach(function(ev) {
            dropZone.addEventListener(ev, function(e) { e.preventDefault(); e.stopPropagation(); });
        });

        ["dragenter", "dragover"].forEach(function(ev) {
            dropZone.addEventListener(ev, function() { dropZone.classList.add("pq-drop-active"); });
        });
        ["dragleave", "drop"].forEach(function(ev) {
            dropZone.addEventListener(ev, function() { dropZone.classList.remove("pq-drop-active"); });
        });

        dropZone.addEventListener("drop", function(e) {
            const files = e.dataTransfer && e.dataTransfer.files;
            if (files && files.length > 0) processFile(files[0]);
        });

        dropZone.addEventListener("click", function() { fileInput.click(); });

        fileInput.addEventListener("change", function() {
            if (fileInput.files && fileInput.files.length > 0) processFile(fileInput.files[0]);
        });

        if (dpiSlider) {
            dpiSlider.addEventListener("input", function() { updateDPI(dpiSlider.value); });
        }
        if (dpiInput) {
            dpiInput.addEventListener("input", function() { updateDPI(dpiInput.value); });
        }

        dpiPresets.forEach(function(btn) {
            btn.addEventListener("click", function() {
                const val = btn.dataset.val;
                if (val) updateDPI(val);
            });
        });

        function processFile(file) {
            if (!file.type.startsWith("image/")) { alert(ui.invalidImageError); return; }
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    currentWidth = img.naturalWidth;
                    currentHeight = img.naturalHeight;
                    if (e.target && e.target.result) showResults(file, e.target.result);
                    calculateSizes();
                };
                if (e.target && e.target.result) img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        function showResults(file, src) {
            resultsArea.classList.remove("pq-hidden");
            dropZone.classList.add("pq-hidden");
            if (previewImg) previewImg.src = src;
            if (fileNameEl) fileNameEl.textContent = file.name;
            if (pixelDimsEl) pixelDimsEl.textContent = currentWidth + " x " + currentHeight + " px";
            if (fileSizeEl) fileSizeEl.textContent = (file.size / (1024 * 1024)).toFixed(2) + " MB";
            if (megapixelsEl) megapixelsEl.textContent = ((currentWidth * currentHeight) / 1000000).toFixed(1) + " MP";
            setTimeout(function() { resultsArea.scrollIntoView({ behavior: "smooth", block: "start" }); }, 100);
        }

        function updateDPI(val) {
            if (dpiSlider) dpiSlider.value = val;
            if (dpiInput) dpiInput.value = val;
            dpiPresets.forEach(function(btn) {
                if (btn.dataset.val === String(val)) {
                    btn.classList.add("pq-preset-active");
                } else {
                    btn.classList.remove("pq-preset-active");
                }
            });
            calculateSizes();
        }

        function updatePrintSizes(inW, inH, cmW, cmH) {
            if (printCmW) printCmW.textContent = cmW.toFixed(1);
            if (printCmH) printCmH.textContent = cmH.toFixed(1);
            if (printInW) printInW.textContent = inW.toFixed(1);
            if (printInH) printInH.textContent = inH.toFixed(1);
        }

        function calculateSizes() {
            if (!currentWidth || !currentHeight || !dpiInput) return;
            const dpi = parseInt(dpiInput.value);
            if (isNaN(dpi) || dpi <= 0) return;
            const inW = currentWidth / dpi, inH = currentHeight / dpi;
            const cmW = inW * 2.54, cmH = inH * 2.54;
            updatePrintSizes(inW, inH, cmW, cmH);
            updateQualityBadge(dpi);
            updateFormatsTable(cmW, cmH);
        }

        function updateQualityBadge(dpi) {
            if (!qualityText || !qualityDesc || !qualityBadge) return;
            if (dpi >= 300) {
                qualityText.textContent = ui.qualityExcellent;
                qualityDesc.textContent = ui.qualityExcellentDesc;
                qualityBadge.className = "pq-quality-badge pq-badge-green";
            } else if (dpi >= 150) {
                qualityText.textContent = ui.qualityGood;
                qualityDesc.textContent = ui.qualityGoodDesc;
                qualityBadge.className = "pq-quality-badge pq-badge-yellow";
            } else if (dpi >= 72) {
                qualityText.textContent = ui.qualityFair;
                qualityDesc.textContent = ui.qualityFairDesc;
                qualityBadge.className = "pq-quality-badge pq-badge-red";
            } else {
                qualityText.textContent = ui.qualityPoor;
                qualityDesc.textContent = ui.qualityPoorDesc;
                qualityBadge.className = "pq-quality-badge pq-badge-slate";
            }
        }

        function updateFormatsTable(cmW, cmH) {
            console.log('DEBUG: updateFormatsTable called, ui.supportedText:', ui.supportedText);
            if (!formatsTableBody) return;
            formatsTableBody.innerHTML = "";
            const imgMin = Math.min(cmW, cmH);
            const imgMax = Math.max(cmW, cmH);
            PAPER_FORMATS.forEach(function(paper) {
                console.log('DEBUG: Processing paper format:', paper.key);
                const paperMin = Math.min(paper.w, paper.h);
                const paperMax = Math.max(paper.w, paper.h);
                const covers = imgMin >= paperMin - 0.1 && imgMax >= paperMax - 0.1;
                const coverage = Math.min(imgMin / paperMin, imgMax / paperMax) * 100;
                const row = document.createElement("tr");
                row.className = "pq-formats-row";
                const statusHtml = covers
                    ? '<span class="pq-status pq-status-ok"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"/></svg> ' + ui.supportedText + '</span>'
                    : '<span class="pq-status pq-status-no"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12,2L1,21H23M12,6L19.53,19H4.47M11,10V14H13V10M11,16V18H13V16"/></svg> ' + ui.notSupportedPrefix + coverage.toFixed(0) + '%)</span>';
                row.innerHTML = '<td class="pq-td pq-td-name">' + getFormatName(paper) + '</td><td class="pq-td pq-td-dim">' + paper.w + ' x ' + paper.h + '</td><td class="pq-td">' + statusHtml + '</td>';
                formatsTableBody.appendChild(row);
            });
        }
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initPQCalc);
    } else {
        initPQCalc();
    }
    document.addEventListener("astro:page-load", initPQCalc);
</script>

<style>
:root {
    --pq-bg: #fff;
    --pq-border: #cbd5e1;
    --pq-primary: #6366f1;
    --pq-primary-light: #e0e7ff;
    --pq-accent: #4f46e5;
}

:global(.theme-dark) {
    --pq-bg: #0f172a;
    --pq-border: #334155;
    --pq-primary: #6366f1;
    --pq-primary-light: rgba(99, 102, 241, 0.2);
    --pq-accent: #818cf8;
}

:global(.pq-wrapper) {
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1rem;
}

.pq-hidden {
  display: none;
}

:global(.pq-drop-zone) {
    position: relative;
    cursor: pointer;
    border: 2px dashed var(--pq-border);
    border-radius: 1rem;
    padding: 3rem;
    transition: border-color 0.3s, background 0.3s;
}

:global(.theme-dark .pq-drop-zone) {
    border-color: var(--pq-border);
}
:global(.pq-drop-zone:hover),
:global(.pq-drop-zone.pq-drop-active) {
    border-color: var(--pq-primary);
    background: rgba(99, 102, 241, 0.04);
}
:global(.pq-drop-inner) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
}
:global(.pq-upload-icon-wrap) {
    width: 5rem;
    height: 5rem;
    background: var(--pq-primary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pq-accent);
    transition: transform 0.3s;
}

:global(.theme-dark .pq-upload-icon-wrap) {
    background: rgba(99, 102, 241, 0.2);
    color: #818cf8;
}
:global(.pq-drop-zone:hover .pq-upload-icon-wrap) {
    transform: scale(1.1);
}
:global(.pq-drop-title) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0;
}

:global(.theme-dark .pq-drop-title) {
    color: #f1f5f9;
}
:global(.pq-drop-sub) {
    color: #64748b;
    margin: 0.25rem 0 0;
    font-size: 0.95rem;
}
:global(.pq-drop-overlay) {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(99,102,241,0.04), rgba(168,85,247,0.04));
    border-radius: 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
}
:global(.pq-drop-zone:hover .pq-drop-overlay) { opacity: 1; }

:global(.pq-results) {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    animation: pq-fade-up 0.5s ease-out;
}

@keyframes pq-fade-up {
    from {
        opacity: 0;
        transform: translateY(1.25rem);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

:global(.pq-file-card) {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    box-shadow: 0 4px 24px -8px rgba(0,0,0,0.1);
    padding: 1.5rem;
}

:global(.theme-dark .pq-file-card) {
    background: #0f172a;
    border-color: #1e293b;
}
:global(.pq-file-left) {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}
:global(.pq-preview-wrap) {
    position: relative;
    width: 8rem;
    height: 8rem;
    flex-shrink: 0;
}
:global(.pq-preview-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
:global(.pq-file-name) {
    font-weight: 700;
    color: #0f172a;
    font-size: 1rem;
    margin: 0 0 0.5rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 20rem;
}

:global(.theme-dark .pq-file-name) {
    color: #f1f5f9;
}
:global(.pq-file-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
}
:global(.pq-meta-item) {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    color: #64748b;
}

:global(.pq-main-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
}

@media (max-width: 640px) {
    .pq-main-grid { grid-template-columns: 1fr; }
}

:global(.pq-config-panel) {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 1.5rem;
}

:global(.theme-dark .pq-config-panel) {
    background: rgba(30, 41, 59, 0.5);
    border-color: var(--pq-border);
}
:global(.pq-config-label) {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    margin-bottom: 1rem;
}

:global(.theme-dark .pq-config-label) {
    color: #94a3b8;
}
:global(.pq-slider) {
    width: 100%;
    height: 0.5rem;
    background: #e2e8f0;
    border-radius: 0.5rem;
    appearance: none;
    cursor: pointer;
    accent-color: #6366f1;
    margin-bottom: 1rem;
}

:global(.theme-dark .pq-slider) {
    background: #334155;
}
:global(.pq-dpi-row) {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
}
:global(.pq-dpi-number) {
    width: 6rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    background: #fff;
    color: #0f172a;
    font-size: 1rem;
    font-weight: 700;
    text-align: center;
    padding: 0.4rem 0.5rem;
    outline: none;
}
:global(.pq-dpi-number:focus) { border-color: var(--pq-primary); }

:global(.theme-dark .pq-dpi-number) {
    background: #0f172a;
    border-color: var(--pq-border);
    color: #f1f5f9;
}
:global(.pq-dpi-label) {
    font-size: 0.875rem;
    color: #64748b;
}
:global(.pq-presets) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}
:global(.pq-preset-btn) {
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 999px;
    background: #e2e8f0;
    color: #475569;
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
}
:global(.pq-preset-btn:hover) { background: #cbd5e1; }

:global(.theme-dark .pq-preset-btn) {
    background: #334155;
    color: #94a3b8;
}

:global(.theme-dark .pq-preset-btn:hover) {
    background: #475569;
}
:global(.pq-preset-active) {
    background: var(--pq-primary-light);
    color: #4338ca;
    box-shadow: 0 0 0 1px rgba(99, 102, 241, 0.2);
}

:global(.theme-dark .pq-preset-active) {
    background: rgba(99, 102, 241, 0.3);
    color: #a5b4fc;
}

:global(.pq-output-panel) {
    display: flex;
}
:global(.pq-output-gradient) {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    border-radius: 0.75rem;
    padding: 1.5rem;
    color: #fff;
    box-shadow: 0 10px 40px -10px rgba(99,102,241,0.4);
    position: relative;
    overflow: hidden;
}
:global(.pq-output-blur-bg) {
    position: absolute;
    top: 0; right: 0;
    width: 8rem; height: 8rem;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    filter: blur(2rem);
    transform: translate(2rem, -2rem);
    pointer-events: none;
}
:global(.pq-output-subtitle) {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(224,231,255,0.9);
    margin: 0 0 0.5rem;
    position: relative;
}
:global(.pq-output-size) {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 0.25rem;
    position: relative;
}
:global(.pq-size-sep) {
    font-size: 1.5rem;
    opacity: 0.5;
}
:global(.pq-size-unit) {
    font-size: 1.5rem;
}
:global(.pq-output-inches) {
    color: rgba(199, 210, 254, 0.8);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    position: relative;
}
:global(.pq-quality-section) {
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.2);
    position: relative;
}
:global(.pq-quality-badge) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 700;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    margin-bottom: 0.5rem;
