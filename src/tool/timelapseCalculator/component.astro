---
import { Icon } from 'astro-icon/components';
import type { TimelapseUI } from './index';
import './style.css';

interface Props {
    ui: TimelapseUI;
}

const { ui } = Astro.props;
---

<div class="timelapse-container" id="timelapse-calculator-root" data-ui={JSON.stringify(ui)}>
    <div class="timelapse-card">
        <div class="params-section">
            <h3 class="section-title">
                <Icon name="mdi:tune-vertical" style="color: var(--accent)" />
                {ui.paramsTitle}
            </h3>

            <div class="input-group">
                <label class="label-title">
                    {ui.eventDuration}
                </label>
                <div class="input-row">
                    <div class="input-field">
                        <label for="event-hours" class="label-sub">{ui.hours}</label>
                        <input
                            type="number"
                            id="event-hours"
                            value="1"
                            min="0"
                            class="input-base"
                        />
                    </div>
                    <div class="input-field">
                        <label for="event-minutes" class="label-sub">{ui.minutes}</label>
                        <input
                            type="number"
                            id="event-minutes"
                            value="0"
                            min="0"
                            max="59"
                            class="input-base"
                        />
                    </div>
                </div>
            </div>

            <div class="input-group">
                <label class="label-title" style="margin-top: 1rem">
                    {ui.videoDuration}
                </label>
                <div class="input-row">
                    <div class="input-field">
                        <label for="video-seconds" class="label-sub">{ui.seconds}</label>
                        <input
                            type="number"
                            id="video-seconds"
                            value="10"
                            min="1"
                            class="input-base"
                        />
                    </div>
                    <div class="input-field">
                        <label for="fps-select" class="label-sub">{ui.fps}</label>
                        <div class="select-wrapper">
                            <select id="fps-select" class="input-base">
                                <option value="24">24</option>
                                <option value="25">25</option>
                                <option value="30">30</option>
                                <option value="60">60</option>
                            </select>
                            <Icon name="mdi:chevron-down" class="select-icon" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="results-section">
            <div>
                <h3 class="results-title">
                    <Icon name="mdi:equal-box" style="color: #fff" />
                    {ui.resultsTitle}
                </h3>

                <div class="result-main">
                    <p class="result-label">
                        {ui.intervalLabel}
                    </p>
                    <div class="result-big-value">
                        <span id="result-interval" class="value-number">
                            15.0
                        </span>
                        <span class="value-unit">{ui.secondsUnit}</span>
                    </div>
                </div>

                <div class="results-grid">
                    <div>
                        <p class="grid-item-label">{ui.totalPhotos}</p>
                        <p id="result-photos" class="grid-item-value">240</p>
                    </div>
                    <div>
                        <p class="grid-item-label">{ui.speed}</p>
                        <p id="result-speed" class="grid-item-value">360x</p>
                    </div>
                    <div>
                        <p class="grid-item-label">{ui.shutterSpeed}</p>
                        <p id="result-shutter" class="grid-item-subvalue">~7.5s (180°)</p>
                    </div>
                    <div>
                        <p class="grid-item-label">{ui.storage}</p>
                        <p id="result-storage" class="grid-item-subvalue">~6 GB</p>
                    </div>
                </div>
            </div>

            <div class="info-footer">
                <Icon name="mdi:information-outline" style="width: 1.25rem; height: 1.25rem" />
                <p>
                    {ui.rule180Info}
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    import { initTimelapseCalculator } from './ui';
    initTimelapseCalculator();
    document.addEventListener('astro:page-load', initTimelapseCalculator);
</script>
